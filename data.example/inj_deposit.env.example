# INJ 链上充值 — 运营方环境变量（复制为本地 data/maneki_inj.env；勿提交真实密钥）
# On-chain INJ recharge — operator env. Copy to data/maneki_inj.env. NEVER commit secrets.

# 收款地址(treasury)：用户把原生 INJ 转到这里，扫描器按【发送方】精确入账、txhash 去重。
# Treasury inj1... address that receives top-ups. Either set it directly…
INJ_TREASURY_ADDRESS=inj1youroperatoraddress
# …or derive it from your operator private key (the address is derived from this):
# MANEKI_INJ_DEPOSIT_PRIVATE_KEY=<hex>

# 充值所在链。Chain the treasury is watched on.
INJ_TREASURY_NETWORK=mainnet            # mainnet | testnet

# 兑换比例：1 INJ = ? 积分。Credits per 1 INJ.
INJ_POINTS_PER_INJ=100

# 每个 agent 决策 tick 消耗多少积分。Credits burned per agent tick.
INJ_POINTS_PER_TICK=1

# 预设充值按钮(积分)。Preset top-up buttons, in 积分.
MANEKI_POINTS_PRESETS=1,5,10,100,200,1000

# 各 agent 共用的 OpenRouter key。Shared OpenRouter key for all agents.
HYPERPILOT_OPENROUTER_KEY=
HYPERPILOT_OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
